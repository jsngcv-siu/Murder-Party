  "components": [
    {
      "name": "Primary Action",
      "kind": "button",
      "refersTo": "button-primary",
      "description": "CTA ficelle rouge unique, tactile et direct.",
      "html": "<button class=\"ds-btn-primary\">CONTINUER</button>",
      "css": ".ds-btn-primary{min-height:44px;padding:12px 16px;border:1px solid oklch(0.62 0.23 20);border-radius:8px;background:var(--primary);color:var(--primary-foreground);font:600 14px/1 var(--font-body);transition:filter 140ms ease,transform 140ms ease}.ds-btn-primary:hover{filter:brightness(1.08)}.ds-btn-primary:active{transform:scale(.97)}.ds-btn-primary:focus-visible{outline:2px solid var(--ring);outline-offset:2px}"
    },
    {
      "name": "Paper Evidence",
      "kind": "card",
      "refersTo": "paper-card",
      "description": "Document clair réservé à un fait, une révélation ou un testament.",
      "html": "<article class=\"ds-paper\"><span class=\"ds-pin\"></span><h3>FAIT ÉTABLI</h3><p>Le manoir conserve cette information.</p></article>",
      "css": ".ds-paper{position:relative;padding:16px;border:1px solid oklch(0.82 0.06 70);border-radius:3px;background:var(--paper);color:var(--paper-ink);box-shadow:var(--shadow-paper);font:400 14px/1.5 var(--font-body)}.ds-paper h3{margin:0 0 8px;font:700 16px/1.2 var(--font-display)}.ds-paper p{margin:0}.ds-pin{position:absolute;top:-6px;left:50%;width:12px;height:12px;transform:translateX(-50%);border-radius:50%;background:var(--primary);box-shadow:var(--shadow-pin)}"
    },
    {
      "name": "Rubber Stamp",
      "kind": "chip",
      "description": "État ou verdict explicite, doublé par un libellé.",
      "html": "<span class=\"ds-stamp\">CONFIDENTIEL</span>",
      "css": ".ds-stamp{display:inline-flex;padding:4px 10px;border:2px solid var(--primary);border-radius:3px;color:var(--primary);font:700 11px/1 var(--font-display);letter-spacing:.1em;transform:rotate(-3deg)}"
    },
    {
      "name": "Dossier Field",
      "kind": "input",
      "description": "Champ mobile sombre, lisible et sans effet décoratif.",
      "html": "<label class=\"ds-field-label\" for=\"ds-code\">CODE DE PARTIE</label><input class=\"ds-field\" id=\"ds-code\" placeholder=\"ABC123\">",
      "css": ".ds-field-label{display:block;margin-bottom:6px;color:var(--muted-foreground);font:600 10px/1.2 var(--font-display);letter-spacing:.12em}.ds-field{box-sizing:border-box;width:100%;min-height:44px;padding:10px 12px;border:1px solid var(--input);border-radius:8px;background:var(--card);color:var(--foreground);font:500 16px/1.4 var(--font-body)}.ds-field::placeholder{color:var(--muted-foreground)}.ds-field:focus-visible{outline:2px solid var(--ring);outline-offset:2px}"
    },
    {
      "name": "Player Bottom Navigation",
      "kind": "nav",
      "refersTo": "active-tab",
      "description": "Navigation familière avec onglet actif marqué par l'or et la couleur de phase.",
      "html": "<nav class=\"ds-nav\"><button>INVENT.</button><button class=\"ds-active\">ANNONCES</button><button>TEST.</button></nav>",
      "css": ".ds-nav{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--border);background:var(--card)}.ds-nav button{position:relative;min-height:58px;border:0;background:transparent;color:var(--muted-foreground);font:500 10px/1.2 var(--font-body)}.ds-nav button:hover{color:var(--foreground)}.ds-nav button:focus-visible{outline:2px solid var(--ring);outline-offset:-3px}.ds-nav .ds-active{color:var(--foreground)}.ds-nav .ds-active::before{content:'';position:absolute;top:0;left:50%;width:32px;height:2px;transform:translateX(-50%);border-radius:2px;background:var(--accent)}"
    },
    {
      "name": "Pinned Player",
      "kind": "custom",
      "description": "Une personne importante représentée comme une photo physique.",
      "html": "<figure class=\"ds-polaroid\"><span class=\"ds-polaroid-pin\"></span><div class=\"ds-photo\">PORTRAIT</div><figcaption>CLÉO</figcaption></figure>",
      "css": ".ds-polaroid{position:relative;width:104px;margin:0;padding:6px 6px 14px;transform:rotate(-2deg);background:#fbfaf6;color:var(--paper-ink);box-shadow:var(--shadow-paper)}.ds-photo{display:grid;height:92px;place-items:center;border:1px solid oklch(0.82 0.04 70);background:oklch(0.88 0.02 75);font:600 10px/1 var(--font-body)}.ds-polaroid figcaption{margin-top:8px;text-align:center;font:700 16px/1 var(--font-hand)}.ds-polaroid-pin{position:absolute;top:-5px;left:50%;width:11px;height:11px;transform:translateX(-50%);border-radius:50%;background:var(--accent);box-shadow:var(--shadow-pin)}"
    }
