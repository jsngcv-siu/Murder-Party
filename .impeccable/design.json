  "narrative": {
    "northStar": "Le dossier vivant",
    "overview": "L'interface évoque des pièces d'enquête réelles dans un manoir. La matérialité reste fonctionnelle : le joueur comprend d'abord ce qui change, puis les détails, puis l'ambiance.",
    "keyCharacteristics": [
      "Dark-only chaud avec papier clair réservé aux faits importants.",
      "Une conséquence principale par premier regard.",
      "Matières fonctionnelles et accents rares.",
      "Navigation familière et secrets strictement préservés."
    ],
    "rules": [
      {
        "name": "The Above-the-Fold Rule",
        "body": "Le contenu attendu apparaît avant les résumés secondaires.",
