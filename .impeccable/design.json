      },
      {
        "name": "The Material Contract",
        "body": "Papier = fait, liège = relation, tampon = état, post-it = annotation, polaroïd = personne, ficelle = action.",
        "section": "colors"
      },
      {
        "name": "The Legibility Rule",
        "body": "Archivo porte toute information nécessaire pour décider ou agir.",
        "section": "typography"
      },
      {
